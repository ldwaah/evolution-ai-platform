rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }

    function isTeacher() {
      return isSignedIn()
        && userData().role == 'teacher'
        && userData().schoolId is string;
    }

    function teacherSchoolId() {
      return userData().schoolId;
    }

    function isStudentSelf(schoolId, studentId) {
      return isSignedIn()
        && request.auth.uid == studentId
        && (userData().role == null || userData().role == 'student')
        && (userData().schoolId == null || userData().schoolId == schoolId);
    }

    function tutorApprovalFieldsOnly() {
      let allowed = [
        'tutorStatus', 'assignedTutorId', 'suggestedTutorId',
        'agentId', 'agentName', 'tutorId', 'tutorName', 'tutorIndex',
        'level', 'levelLabel',
        'tutorApprovedAt', 'tutorApprovedBy', 'updatedAt'
      ];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /schools/{schoolId} {
      allow read: if isTeacher() && teacherSchoolId() == schoolId;

      match /teachers/{teacherId} {
        allow read: if isSignedIn() && request.auth.uid == teacherId;
        allow create, update: if isTeacher()
          && teacherSchoolId() == schoolId
          && request.auth.uid == teacherId;
      }

      match /students/{studentId} {
        allow read: if isStudentSelf(schoolId, studentId)
          || (isTeacher() && teacherSchoolId() == schoolId);

        allow create, update: if isStudentSelf(schoolId, studentId);

        allow update: if isTeacher()
          && teacherSchoolId() == schoolId
          && tutorApprovalFieldsOnly();

        match /progress/{docId} {
          allow read: if isStudentSelf(schoolId, studentId)
            || (isTeacher() && teacherSchoolId() == schoolId);
          allow write: if isStudentSelf(schoolId, studentId);
        }

        match /events/{eventId} {
          allow read: if isStudentSelf(schoolId, studentId)
            || (isTeacher() && teacherSchoolId() == schoolId);
          allow create: if isStudentSelf(schoolId, studentId);
        }

        match /signals/{signalId} {
          allow read: if isStudentSelf(schoolId, studentId)
            || (isTeacher() && teacherSchoolId() == schoolId);
          allow create: if isStudentSelf(schoolId, studentId);
        }
      }
    }
  }
}
